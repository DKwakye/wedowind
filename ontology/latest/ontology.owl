<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/wedowind/ontology#"
     xml:base="https://w3id.org/wedowind/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/wedowind/ontology#">
        <terms:creator>Daniel Kwakye</terms:creator>
        <rdfs:comment xml:lang="en">Ontology for wind energy benchmarking challenges, training, and interdisciplinary research. Extends schema.org, DDI lifecycle, SKOS, and PROV-O.</rdfs:comment>
        <rdfs:label xml:lang="en">WeDoWind Ontology</rdfs:label>
        <owl:versionInfo>2.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#duration -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#duration"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/prov#wasDerivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom"/>
    


    <!-- https://w3id.org/wedowind/ontology#addressesCompetency -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#addressesCompetency">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Competency"/>
        <rdfs:comment xml:lang="en">Links a challenge task to the skill area it develops or assesses.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses competency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#constructs -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#constructs">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#SurveyInstrument"/>
        <rdfs:range rdf:resource="https://schema.org/DefinedTerm"/>
        <rdfs:comment xml:lang="en">Theoretical constructs measured by a survey instrument.</rdfs:comment>
        <rdfs:label xml:lang="en">constructs</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#detectsFailureMode -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#detectsFailureMode">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#FailureMode"/>
        <rdfs:comment xml:lang="en">Specifies the type of turbine failure a task aims to detect or predict.</rdfs:comment>
        <rdfs:label xml:lang="en">detects failure mode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#entrySubmission -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#entrySubmission">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#LeaderboardEntry"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:comment xml:lang="en">Links a leaderboard entry to the submission it represents.</rdfs:comment>
        <rdfs:label xml:lang="en">entry submission</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#evaluatedByMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#evaluatedByMetric">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#EvaluationMetric"/>
        <rdfs:comment xml:lang="en">Links a submission to the metrics used for its evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluated by metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#evaluatedWith -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#evaluatedWith">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#LeaderboardEntry"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#EvaluationMetric"/>
        <rdfs:comment xml:lang="en">Specifies which evaluation metric a leaderboard entry value corresponds to.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluated with metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasLeaderboardEntry -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasLeaderboardEntry">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#LeaderboardEntry"/>
        <rdfs:comment xml:lang="en">Links a challenge to entries on its leaderboard.</rdfs:comment>
        <rdfs:label xml:lang="en">has leaderboard entry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasMethodType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasMethodType">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ComputationalMethod"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#MethodType"/>
        <rdfs:comment xml:lang="en">Links a computational method to a controlled vocabulary term describing its methodological category.</rdfs:comment>
        <rdfs:label xml:lang="en">has method type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasSoftwareSourceCode -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasSoftwareSourceCode">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:range rdf:resource="https://schema.org/SoftwareSourceCode"/>
        <rdfs:comment xml:lang="en">Links a tutorial to accompanying code repository.</rdfs:comment>
        <rdfs:label xml:lang="en">has software source code</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasSubmission -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasSubmission">
        <rdfs:domain rdf:resource="https://schema.org/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:comment xml:lang="en">Inverse property linking a person or organization (agent) to their submissions.</rdfs:comment>
        <rdfs:label xml:lang="en">has submission</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasTask -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasTask">
        <owl:inverseOf rdf:resource="https://w3id.org/wedowind/ontology#isTaskOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:comment xml:lang="en">Links a challenge to its constituent tasks.</rdfs:comment>
        <rdfs:label xml:lang="en">has task</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasTutorial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#hasTutorial">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:comment xml:lang="en">Links a challenge task to recommended training materials.</rdfs:comment>
        <rdfs:label xml:lang="en">has tutorial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#implementsMethod -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#implementsMethod">
        <owl:inverseOf rdf:resource="https://w3id.org/wedowind/ontology#isImplementedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#ComputationalMethod"/>
        <rdfs:comment xml:lang="en">Links a submission to the computational method it implements.</rdfs:comment>
        <rdfs:label xml:lang="en">implements method</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#includesChallenge -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#includesChallenge">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#TrainingPathway"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:comment xml:lang="en">Links a training pathway to a challenge that serves as practical assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">includes challenge</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#includesTutorial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#includesTutorial">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#TrainingPathway"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:comment xml:lang="en">Links a training pathway to a tutorial that is part of the curriculum.</rdfs:comment>
        <rdfs:label xml:lang="en">includes tutorial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#isImplementedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#isImplementedIn">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ComputationalMethod"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:comment xml:lang="en">Inverse property linking a method to submissions that use it.</rdfs:comment>
        <rdfs:label xml:lang="en">is implemented in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#isPrerequisiteFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#isPrerequisiteFor">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:comment xml:lang="en">Indicates that one tutorial must be completed before another.</rdfs:comment>
        <rdfs:label xml:lang="en">is prerequisite for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#isTaskOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#isTaskOf">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:comment xml:lang="en">Inverse property linking a task back to its parent challenge.</rdfs:comment>
        <rdfs:label xml:lang="en">is task of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#locatedAt -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#locatedAt">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#WindTurbine"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#WindFarm"/>
        <rdfs:comment xml:lang="en">Links a turbine to the wind farm where it is installed.</rdfs:comment>
        <rdfs:label xml:lang="en">located at</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#organizedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#organizedBy">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">The organization responsible for hosting and managing a challenge.</rdfs:comment>
        <rdfs:label xml:lang="en">organized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#participatedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#participatedBy">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="https://schema.org/Person"/>
        <rdfs:comment xml:lang="en">Persons or organizations that participated in a challenge.</rdfs:comment>
        <rdfs:label xml:lang="en">participated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#rankedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#rankedIn">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#LeaderboardEntry"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:comment xml:lang="en">Links a leaderboard entry to the challenge in which the ranking is defined.</rdfs:comment>
        <rdfs:label xml:lang="en">ranked in challenge</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#reference -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#reference">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Reference"/>
        <rdfs:comment xml:lang="en">Links a creative work to a reference describing its relationship to another resource.</rdfs:comment>
        <rdfs:label xml:lang="en">reference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#referenceMetadata -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#referenceMetadata">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Reference"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#ReferenceMetadata"/>
        <rdfs:comment xml:lang="en">Links a reference to its associated provenance metadata.</rdfs:comment>
        <rdfs:label xml:lang="en">reference metadata</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#relatedDataset -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#relatedDataset">
        <rdfs:domain rdf:resource="https://schema.org/CreativeWork"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#relatedPublication -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#relatedPublication">
        <rdfs:domain rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.org/ScholarlyArticle"/>
        <rdfs:comment xml:lang="en">Links a resource to scholarly articles describing or using it.</rdfs:comment>
        <rdfs:label xml:lang="en">related publication</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#relatedVariable -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#relatedVariable">
        <rdfs:domain rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Variable"/>
        <rdfs:comment xml:lang="en">Links a resource to variables it uses or describes.</rdfs:comment>
        <rdfs:label xml:lang="en">related variable</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#solvesTask -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#solvesTask">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:comment xml:lang="en">Links a submission to the specific challenge task it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">solves task</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#submittedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#submittedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/wedowind/ontology#hasSubmission"/>
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="https://schema.org/Person"/>
        <rdfs:comment xml:lang="en">The person or organization responsible for a submission.</rdfs:comment>
        <rdfs:label xml:lang="en">submitted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#targetsCompetency -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#targetsCompetency">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#Competency"/>
        <rdfs:comment xml:lang="en">Indicates the competency a tutorial aims to teach or develop.</rdfs:comment>
        <rdfs:label xml:lang="en">targets competency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#usedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#usedIn">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#SurveyInstrument"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#usesDatasetForSubmission -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#usesDatasetForSubmission">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Submission"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#usesDatasetForTask -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#usesDatasetForTask">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://schema.org/Dataset"/>
        <rdfs:comment xml:lang="en">Links a challenge task to the dataset officially provided for that task.</rdfs:comment>
        <rdfs:label xml:lang="en">uses dataset for task</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wedowind/ontology#usesTurbine -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wedowind/ontology#usesTurbine">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#ChallengeTask"/>
        <rdfs:range rdf:resource="https://w3id.org/wedowind/ontology#WindTurbine"/>
        <rdfs:comment xml:lang="en">Links a challenge task to specific turbine instances or types used in the task.</rdfs:comment>
        <rdfs:label xml:lang="en">uses turbine</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://schema.org/identifier -->


    <owl:DatatypeProperty rdf:about="https://schema.org/identifier"/>
    


    <!-- https://w3id.org/wedowind/ontology#analysisUnit -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#analysisUnit">
        <rdfs:domain rdf:resource="https://schema.org/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unit: individual, household, turbine, farm, blade, component.</rdfs:comment>
        <rdfs:label xml:lang="en">analysis unit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#collectionDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#collectionDate">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#SurveyVariable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when a survey response was collected.</rdfs:comment>
        <rdfs:label xml:lang="en">collection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#dataResolution -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#dataResolution">
        <rdfs:domain rdf:resource="https://schema.org/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Temporal resolution of time-series data (e.g., 1Hz, 10min, 1day).</rdfs:comment>
        <rdfs:label xml:lang="en">data resolution</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#difficultyLevel -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#difficultyLevel">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Difficulty classification: beginner, intermediate, or advanced.</rdfs:comment>
        <rdfs:label xml:lang="en">difficulty level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#doi -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#doi">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/identifier"/>
        <rdfs:comment xml:lang="en">Digital Object Identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">DOI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#downloadURL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#downloadURL">
        <rdfs:domain rdf:resource="https://schema.org/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Direct URL for downloading a dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">download URL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#endDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#endDate">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Challenge"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">End date of a challenge.</rdfs:comment>
        <rdfs:label xml:lang="en">end date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#estimatedTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wedowind/ontology#estimatedTime">
        <rdfs:domain rdf:resource="https://w3id.org/wedowind/ontology#Tutorial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="en">Estimated duration to complete a tutorial (ISO 8601 format).</rdfs:comment>
        <rdfs:label xml:lang="en">estimated time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wedowind/ontology#hasModelArtifact -->


